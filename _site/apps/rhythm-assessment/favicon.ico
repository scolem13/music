<!DOCTYPE html>
<html lang="en">

<head>
	<meta charset="utf-8">
	<meta http-equiv="x-ua-compatible" content="ie=edge">
	<meta name="viewport" content="width=device-width, initial-scale=1">
	<link rel="icon" href="favicon.ico" type="image/x-icon" />
	<link rel="stylesheet" type="text/css" href="abcjs-audio.css">
	<link rel="stylesheet" href="examples-styles.css" />

	<title>Multi Pattern</title>
	<script src="abcjs-basic.js" type="text/javascript"></script>
	<script src="pattern-object.js" type="text/javascript"></script>
	<script type="text/javascript">
		
		var editor;
		var outputEl;
		var abcEl;
		const abcList = [];
		let solfegeString = "";
		
		function showOptions(){
		var more = document.getElementById('more');
		var tuneSelector = document.getElementById('tune-selector');
			if (document.getElementById("show-options").checked){
			more.style.display = 'flex';
			tuneSelector.style.display = "block";
			} else {
			more.style.display = 'none';	
			tuneSelector.style.display = "none";

			}
		}

		function showNotes(){
		var main = document.getElementById('main');
			if (document.getElementById("show-notes").checked){
			main.style.display = 'block';
			} else {
			main.style.display = 'none';	
			}
			paramChanged();
		}

		function showSolfege(){
		var solfegeDisplay = document.getElementById('solfege-display');
			if (document.getElementById("show-solfege").checked){
			solfegeDisplay.style.display = 'flex';
			} else {
			solfegeDisplay.style.display = 'none';	
			}
		}
		
		let currentTune = 0;
		secondOctave = [0, 0, 0, 0];

		function refreshSongbook(){
			//fix scope problems:
			// returning abcString

			pattern = document.getElementById("pattern-selector").value;
			abcList.length = 0;
			//let abcString = document.getElementById(pattern).value;
			let abcString = patternObject[pattern];
			var tuneBook = new ABCJS.TuneBook(abcString);
			var selectTune = document.getElementById("tune-selector");
			selectTune.innerHTML = "";

			var option = document.createElement("option");
			for (var i = 0; i < tuneBook.tunes.length; i++) {
				//reset option
				option = document.createElement("option");
				optionContent = document.createTextNode(tuneBook.tunes[i].id);
				abcList.push(tuneBook.tunes[i].abc);
				// console.log(abcList[i]);
				option.appendChild(optionContent);
				option.setAttribute('value', i)
				selectTune.appendChild(option)
			}
			// console.log(abcList);
			paramChanged();
			}
		
		function moveStuff(target, aspect, source){
			let myTarget = document.getElementById(target);
			let val = document.getElementById(source).value + "%";
			myTarget.style[aspect] = val;
		}

		function nextTune(){
			currentTune++;
			if (currentTune >= abcList.length)
				currentTune = 0;
			document.getElementById('tune-selector').value = currentTune;
			paramChanged();
		}

		function randomTune(){
			let oldTune = currentTune;
			let tuneSelector = document.getElementById('tune-selector');
			let allTunes = tuneSelector.getElementsByTagName('option');
			let tuneIndex = Math.floor(Math.random() * allTunes.length);
			tuneSelector.selectedIndex = tuneIndex;
			currentTune = tuneIndex;
			if (currentTune == oldTune){
				randomTune();
			}
			paramChanged();
		}

		function octaveToChange(i){
			let box = `second-octave-box${i}`;
			secondOctave[i] = document.getElementById(box).checked
			paramChanged();
		}

		function octaveAll(n){
			for (i = 0; i < 4; i++){
				let oct = `octave-transpose${parseInt(i)}`;
				let m = parseInt(document.getElementById(oct).value);
				document.getElementById(oct).value = m + n;
			}
			paramChanged();	
		}
		

		window.onload = function () {
			abcEl = document.querySelector("#abc");
			outputEl = document.querySelector("#transposed");
			visualTransposeEl = document.querySelector(".transpose");
			var renderParams = { responsive: "resize", selectTypes: false, visualTranspose: 12,  };
			editor = new ABCJS.Editor("major-stepwise", {
				canvas_id: "paper0",
				warnings_id: "warnings",
				abcjsParams: renderParams,
			});

			

			


			//visualTransposeEl.addEventListener("change", paramChanged);
			
			paramChanged(false);
		};

		function paramChanged(userAction) {
			
			let semis = parseInt(document.getElementById("vis-transpose").value);
			let octs0 = parseInt(document.getElementById("octave-transpose0").value);
			let octs1 = parseInt(document.getElementById("octave-transpose1").value);
			let octs2 = parseInt(document.getElementById("octave-transpose2").value);
			let octs3 = parseInt(document.getElementById("octave-transpose3").value);
			
			var renderParams = { responsive: "resize", selectTypes: false, visualTranspose: 12 + semis + octs0 * 12};
			var renderParams2 = { responsive: "resize", selectTypes: false, visualTranspose: 2 + semis + octs1 * 12};
			var renderParams4 = { responsive: "resize", selectTypes: false, visualTranspose: 9 + semis + octs2 * 12};
			var renderParams3 = { responsive: "resize", selectTypes: false, visualTranspose: -12 + semis + octs3 * 12};
			
		

			
			var selectTune = document.getElementById("tune-selector");
			currentTune =  document.getElementById('tune-selector').value;
			let inst = 4;
			let tune = abcList[currentTune];
			solfegeString = "";
			tune = tune.split("\n");
			for(i of tune){
				if(i.startsWith("w: ")){
					solfegeString = i.slice(3,);
				} 
				else if(i.startsWith("w:")){
					solfegeString = i.slice(2,);
				}
			}
			let solfegeDisplay = document.getElementById("solfege-display");
			solfegeDisplay.innerHTML = solfegeString;
			tune[0] += `\n%%MIDI program ${inst} `;
			tune[0] += '\nM:none'
			tune[0] += `\n%%staffwidth 100`;
			tune[0] += `\n%%score (V1 V2)`;
			tune = tune.join("\n");
			
			function octaver(tune, index){
				let tuneCopy = tune;
				if (!secondOctave[index]){
					tuneCopy = tuneCopy.split("\n");
					tuneCopy.pop();
					tuneCopy.pop();
					tuneCopy = tuneCopy.join("\n");
				}
				return tuneCopy
			}

			var visualObj = ABCJS.renderAbc("paper0", octaver(tune, 0), renderParams)[0];
			//var tune= document.getElementById("tune").value;
			var VisualObj2 = ABCJS.renderAbc("paper1", octaver(tune, 1), renderParams2);
			let tuneBass = tune.split("\n");
			tuneBass[0] += "\nK: clef=bass";
			tuneBass = tuneBass.join("\n");	
			var VisualObj3 = ABCJS.renderAbc("paper2", octaver(tuneBass, 2), renderParams3);
			var VisualObj4 = ABCJS.renderAbc("paper3", octaver(tune, 3), renderParams4);
			
			const synthOpts = {
			//definitely mess with this for transposition
			midiTranspose: semis,
			 //voicesOff: true,
			// chordsOff: !playChords,
			// voicesOff: !playTune
		}

			createSynth(visualObj, synthOpts);

		}

		var synthControl

		

		function createSynth(visualObj, synthOpts) {
			let semis = parseInt(document.getElementById("vis-transpose").value);


		

			if (true) {
				synthControl = new ABCJS.synth.SynthController();
				synthControl.load("#audio", null, { displayRestart: true, displayPlay: true, displayProgress: true });
			}
			var midiBuffer = new ABCJS.synth.CreateSynth();
			midiBuffer.init({
				visualObj: visualObj,
				options: {
					soundFontUrl: "https://paulrosen.github.io/midi-js-soundfonts/MusyngKite/" ,
					
				}
			}).then(function (response) {
				synthControl.setTune(visualObj, true, synthOpts).then(function (response) {
				}).catch(function (error) {
					console.warn("Audio problem:", error);
				});
			}).catch(function (error) {
				console.warn("Audio problem:", error);
			});

		}
	</script>
	<style>
		@media only screen and (min-width: 700px) {
			.container {
				/* max-width: 1200px; */
			}
		}

		.input,
		.output {
			display: flex;
			column-gap: 10px;
			margin: 0;
		}

		/* .input>div, */
		.output>div {
			width: 100%;
			height: 100%;
		}

		#abcString, #transposed {
			font-family: monaco, monospace;
			font-size: 1em;
			height: 300px;
		}

		#transposed {
			border: 1px solid #888;
			padding: 10px;
			margin-top: 0;
			overflow: auto;
		}
		label {
			margin-top: 10px;
			display: block;
		}

		textarea{
			display:none;
		}

		pre, #warnings{
			display: none;
		}

		#paper3{
			/* margin-top: 7.35%; */
		}

		.stupid-label {
			margin-right: 5px;
			margin-left: 5px;
		}

		.buddy{
	display: flex;
	margin: 2px 6px;
	padding: 1px;
	text-align: center;
	align-items: center;
	justify-content: center;
}

		.number-input-label{
			display: inline-block;
			margin: 6px 6px;
		}

		select{
			width: 45px;
			height: 30px;
		}

		input{
			width: 60px;
		}

		.octave-transpose{
			width: 40px;
		}

		.checkbox{
			width: 25px;
			height: 25px;
		}

		div.inflow {
		position: relative; 
		display: flex;
		justify-content: center;
		align-items: center;
		}

		#the-bottom{
			position: fixed; 
  			bottom: 30px;
			display: flex;
			flex-wrap: wrap;
			justify-content: center;
		}

		#more{
			display: none;
			flex-wrap: wrap;
			/* margin-top: -20px; */
			/* padding: -10px; */
		}

		#audio{
			width: 200px;
			position: fixed; 
  			bottom: 1vh;
			margin: auto;
		}

		#pattern-selector{
			width: max-content;
		}

		text[font-family*="Times New Roman"]{
		display:none;
		font-weight: normal;
		font-family: sans-serif;
		/* font-size: 2em; */
		transform: translate(5px);
		
		}

		/* this targets the chords
		text[font-family*="Helvetica"]{
			font-style: italic;
			color:red;
			display: none;
		} */


		path{
			/* display:none; */
		}

		svg{
			/* width: 100%
		} */
		}
		main{
			/* display: none; */
		}

		#solfege-display{
		
		height: 90%; 
		width:100%;
		display:flex;
		align-self: top;
		align-content:flex-start;
		justify-content: center;
		font-weight: bolder;
		font-size: 12vw;
		display: none;
		}

		#selections{
			display: flex;
			margin: 6px 10%;
			/* align-items: baseline; */
		}

		/* .bottom-label{
			display: inline-block;
		} */

		.abcjs-midi-clock{
			display:none;
		}
		
		
		
	</style>
</head>

<body>

	<div class="container">
		<main id="main">
			<section class="input">	
				<div>
					


					<!-- <label>Transpose:
						<input
							class="transpose"
							type="number"
							min="-24"
							max="24"
							step="1"
							value="0">
					</label> -->
				</div>
				<div>
					<pre id="transposed"></pre>
					
				</div>
			</section>

			<div id="warnings"></div>
			<section class="output">
				<div>
					<div id="paper0"></div>
				</div>
				<div>
					<div id="paper1"></div>
				</div>
				
			</section>
			<!-- <div><br></div> -->
			<section class="output">
				<div>
					<div id="paper2"></div>
				</div>
				<div>
					<div id="paper3"></div>
				</div>
			</section>
			
		</main>
	</div>
	<p class="solfege-display" id="solfege-display">Do Re Mi</p>
	<div class="inflow">
	
		<div id = "the-bottom" class="the-bottom">
		<div id="audio"></div>
		<div id = "selections" class="buddy">
			<div class="buddy">
			
			</div>
			<button type="button" onclick="nextTune()">Next</button>
			<button type="button" onclick="randomTune()">Random</button>
			<!-- <label for="number-input-label">Tune: </label> -->
			<!-- <p class="stupid-label">Pattern:</p> -->
			<select id = "pattern-selector" onchange="refreshSongbook();  paramChanged()">
				<!-- document.location.reload(); -->
				<!-- fix this by fixing order of calls -->
			<option value = "major-stepwise">Placeholder that shouldn't need to exist, but if I get rid of this option, everything breaks</option>
			</select>
			<select id="tune-selector" onchange="paramChanged()"></select>
			<div class="buddy">
				<label class="bottom-label">Opts?</label>
				<input type="checkbox" id = "show-options" class="checkbox show-options" onchange="showOptions()">
			</div>

			<div class="buddy">
				<label class="notes-label">Notes?</label>
				<input type="checkbox" checked id = "show-notes" class="checkbox show-notes" onchange="showNotes()">
			</div>

			<div class="buddy">
				<label class="solfege-label">Solfege?</label>
				<input type="checkbox" id = "show-solfege" class="checkbox show-solfege" onchange="showSolfege()">
			</div>
			
		</div>
		
		<div id="more" class="buddy more">
			<label for="vis-transpose" class = "number-input-label">Semitones: </label>
			<input id = "vis-transpose" class="number-input vis-transpose" value="0" type="number" min="-12" max="12" onkeyup="if(value<-12) value=-12; if(value>12) value=12;" oninput="paramChanged()">
			<div class="buddy">
			<label for="octave-tranpose" class = "number-input-label">Octaves: </label>
			<button type="button" onclick="octaveAll(-1)">-</button>
			<input id = "octave-transpose0" class="number-input octave-transpose" value="0" type="number" min="-2" max="2" onkeyup="if(value<-2) value=-2; if(value>2) value=2;" oninput="paramChanged()">
			<input id = "octave-transpose1" class="number-input octave-transpose" value="0" type="number" min="-2" max="2" onkeyup="if(value<-2) value=-2; if(value>2) value=2;" oninput="paramChanged()">
			<input id = "octave-transpose3" class="number-input octave-transpose" value="0" type="number" min="-2" max="2" onkeyup="if(value<-2) value=-2; if(value>2) value=2;" oninput="paramChanged()">
			<input id = "octave-transpose2" class="number-input octave-transpose" value="0" type="number" min="-2" max="2" onkeyup="if(value<-2) value=-2; if(value>2) value=2;" oninput="paramChanged()">
			<button type="button" onclick="octaveAll(1)">+</button>
			</div>

			<!-- <p class="trial-text" id="trial-text">Text</p> -->
			<div class="buddy">
			<label for="paper0-top" class = "number-input-label">Top: </label>
			<input id = "paper0-top" class="trial" value="-12" type="number" oninput = "moveStuff('paper0', 'marginTop', 'paper0-top')">
			<input id = "paper1-top" class="trial" value="-12" type="number" oninput = "moveStuff('paper1', 'marginTop', 'paper1-top')">
			<input id = "paper2-top" class="trial" value="5" type="number" oninput = "moveStuff('paper2', 'marginTop', 'paper2-top')">
			<input id = "paper3-top" class="trial" value="-3" type="number" oninput = "moveStuff('paper3', 'marginTop', 'paper3-top')">
			</div>
		
			<div class="buddy">
			<p class="stupid-label">Oct 2? </p>
			<input id = "second-octave-box0" class = "checkbox" type="checkbox" onchange="octaveToChange(0)">
			<input id = "second-octave-box1" class = "checkbox" type="checkbox" onchange="octaveToChange(1)">
			<input id = "second-octave-box2" class = "checkbox" type="checkbox" onchange="octaveToChange(2)">
			<input id = "second-octave-box3" class = "checkbox" type="checkbox" onchange="octaveToChange(3)">
			</div>
		</div>
		</div>
	</div>

	
<script>
	refreshSongbook();
	//document.getElementById("tune-selector").focus();

	// var input = document.getElementById("myInput");
	// input.addEventListener("keyup", function(event) {
    // if (event.keyCode === 13) {
    //     event.preventDefault();
    //     document.getElementById("myBtn").click();
    // }
// });

	for (i = 0; i < 4; i ++){
		console.log(`paper${i}-top`)
		moveStuff(`paper${i}`, 'marginTop', `paper${i}-top`)
		
	}

	var selectPattern = document.getElementById("pattern-selector");
			selectPattern.innerHTML = "";
			var option = document.createElement("option");
			for (i in patternObject) {
				option = document.createElement("option");
				optionContent = document.createTextNode(i);
				option.appendChild(optionContent);
				option.setAttribute('value', i)
				selectPattern.appendChild(option)
			}
</script>
</body>

</html>