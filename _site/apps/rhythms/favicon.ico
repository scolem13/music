	<script src="abcjs-basic.js" type="text/javascript"></script>
	<script src="rhythm-pattern-object.js" type="text/javascript"></script>
	<script type="text/javascript">
		function showCursor(){
		var theCursor = document.getElementById('abcjs-cursor');
			if (document.getElementById("show-cursor").checked){
		theCursor.style.display = 'block';
		} else {
		theCursor.style.display = 'none';	
		}
	}

	function setRests(){
		if (document.getElementById("set-rests").checked){
			rests = true;
		} else {
			rests = false;	
		}
		setTune();
	}


	function showOptions(){
		var theBottom = document.getElementById('the-bottom');
			if (document.getElementById("show-options").checked){
		theBottom.style.display = 'block';
		} else {
		theBottom.style.display = 'none';	
		}
	}

	// midi instrument list

	function disabler(elementId, order){
			// Check
			if (order){
				document.getElementById(elementId).disabled = true;
			} else{
			// Uncheck
			document.getElementById(elementId).disabled = false;
			}
		}
	

		function CursorControl() {
			var self = this;

			self.onReady = function() {
				var downloadLink = document.querySelector(".download");
				downloadLink.addEventListener("click", download);
				downloadLink.setAttribute("style", "");
				var clickEl = document.querySelector(".click-explanation")
				clickEl.setAttribute("style", "");
			};
			self.onStart = function() {
				var svg = document.querySelector("#paper svg");
				var cursor = document.createElementNS("http://www.w3.org/2000/svg", "line");
				cursor.setAttribute("class", "abcjs-cursor");
				cursor.setAttribute("id", "abcjs-cursor")
				cursor.setAttributeNS(null, 'x1', 0);
				cursor.setAttributeNS(null, 'y1', 0);
				cursor.setAttributeNS(null, 'x2', 0);
				cursor.setAttributeNS(null, 'y2', 0);
				svg.appendChild(cursor);

			};
			self.beatSubdivisions = 2;
			self.onBeat = function(beatNumber, totalBeats, totalTime) {
				if (!self.beatDiv)
					self.beatDiv = document.querySelector(".beat");
				self.beatDiv.innerText = "Beat: " + beatNumber + " Total: " + totalBeats + " Total time: " + totalTime;
			};
			self.onEvent = function(ev) {
				if (ev.measureStart && ev.left === null)
					return; // this was the second part of a tie across a measure line. Just ignore it.

				var lastSelection = document.querySelectorAll("#paper svg .highlight");
				for (var k = 0; k < lastSelection.length; k++)
					lastSelection[k].classList.remove("highlight");

				var el = document.querySelector(".feedback").innerHTML = "<div class='label'>Current Note:</div>" + JSON.stringify(ev, null, 4);
				for (var i = 0; i < ev.elements.length; i++ ) {
					var note = ev.elements[i];
					for (var j = 0; j < note.length; j++) {
						note[j].classList.add("highlight");
					}
				}

				var cursor = document.querySelector("#paper svg .abcjs-cursor");
				if (cursor) {
					cursor.setAttribute("x1", ev.left - 2);
					cursor.setAttribute("x2", ev.left - 2);
					cursor.setAttribute("y1", ev.top);
					cursor.setAttribute("y2", ev.top + ev.height);
				}
			};
			self.onFinished = function() {
				var els = document.querySelectorAll("svg .highlight");
				for (var i = 0; i < els.length; i++ ) {
					els[i].classList.remove("highlight");
				}
				var cursor = document.querySelector("#paper svg .abcjs-cursor");
				if (cursor) {
					cursor.setAttribute("x1", 0);
					cursor.setAttribute("x2", 0);
					cursor.setAttribute("y1", 0);
					cursor.setAttribute("y2", 0);
				}
			};
		}

		

		let abc = [];
		let bars = [];
		let details = "";
		let ab;
		let rests = false;

		ab = patternObject["Duple-M-m-4-4"];

		var tuneNames = [ "Cooleys", "Bill Bailey", "All Notes On Piano" ];

		var currentTune = 0;

		var synthControl;

		function checkChanger(elementId, order){
			// Check
			if (order){
				document.getElementById(elementId).checked = true;
			} else{
			// Uncheck
			document.getElementById(elementId).checked = false;
			}
			pickTune();
		}

		function clefHandler(){
			let inst = document.getElementById("inst-select").value;
			switch(inst){
				case "Flute":
				case "Clarinet": 
				case "Alto Sax":
				case "Trumpet":
					checkChanger("bass-clef", false);
					disabler("bass-clef", true);
					break;

				case "Trombone":
				case "Tuba":
					checkChanger("bass-clef", true);
					disabler("bass-clef", true);
					break;

				case "Piano":
				case "Percussion":
					checkChanger("bass-clef", false);
					disabler("bass-clef", false);
			}
		}

		function clickListener(abcElem, tuneNumber, classes, analysis, drag, mouseEvent) {
			var output = "currentTrackMilliseconds: " + abcElem.currentTrackMilliseconds + "<br>" +
				"currentTrackWholeNotes: " + abcElem.currentTrackWholeNotes + "<br>" +
				"midiPitches: " + JSON.stringify(abcElem.midiPitches, null, 4) + "<br>" +
				"gracenotes: " + JSON.stringify(abcElem.gracenotes, null, 4) + "<br>" +
				"midiGraceNotePitches: " + JSON.stringify(abcElem.midiGraceNotePitches, null, 4) + "<br>";
			document.querySelector(".clicked-info").innerHTML = "<div class='label'>Clicked info:</div>" +output;

			var lastClicked = abcElem.midiPitches;
			if (!lastClicked)
				return;

			ABCJS.synth.playEvent(lastClicked, abcElem.midiGraceNotePitches, synthControl.visualObj.millisecondsPerMeasure()).then(function (response) {
				console.log("note played");
			}).catch(function (error) {
				console.log("error playing note", error);
			});
		}

		function refreshSongbook(someAbc){

			var tuneBook = new ABCJS.TuneBook(someAbc);
			var selectTune = document.getElementById("tune-selector");
			selectTune.innerHTML = "";
			abc.length = 0;
			bars.length = 0;
			var option = document.createElement("option");			
			for (var i = 0; i < tuneBook.tunes.length; i++) {
				option = document.createElement("option");
				optionContent = document.createTextNode(tuneBook.tunes[i].id);
				let abcString = tuneBook.tunes[i].abc
				abc.push(abcString);
				abcString = abcString.split("\n");
				if (!(i == tuneBook.tunes.length - 1)){
					abcString.pop();
				}
				let bar = abcString.pop();
				abcString.shift();
				abcString = abcString.join("\n");
				details = abcString;
				bars.push(bar);
				
				option.appendChild(optionContent);
				option.setAttribute('value', i);
				selectTune.appendChild(option);
			}
			console.log(details);
			console.log(bars);

			
		}

		

		function refreshCollection(){
			let collection = document.getElementById("collection-selector").value;
			console.log(collection);
			let ab = patternObject[collection];
			//refreshSongbook();
			
			refreshSongbook(ab);
			pickTune();
			
		}

		function load() {
			var selectCollection = document.getElementById("collection-selector");
			selectCollection.innerHTML = "";
			var option = document.createElement("option");
			for (i in patternObject) {
				option = document.createElement("option");
				optionContent = document.createTextNode(i);
				option.appendChild(optionContent);
				option.setAttribute('value', i)
				selectCollection.appendChild(option)
			}
			//var tuneBook = new ABCJS.TuneBook(ab);
			var selectTune = document.getElementById("tune-selector");
			//var option = document.createElement("option");
			// var optionContent = document.createTextNode("-- select tune --");
			// option.appendChild(optionContent);
			//selectTune.appendChild(option);
			// instead create list from names and getTuneByTitle
			// or set value to name of tune
			// create list for tunes from tuneBook
			// refreshCollection();
			

			refreshSongbook(ab);

			
			

			

			// select.addEventListener("change", setTune)
			document.querySelector(".next").addEventListener("click", next);
			// document.querySelector(".start").addEventListener("click", start);
			document.querySelector(".warp").addEventListener("click", warp);
			document.querySelector(".seek").addEventListener("click", seek);
			document.querySelector(".seek2").addEventListener("click", seek2);
			document.querySelector("#seek-units").addEventListener("change", seekExplanation);

			if (ABCJS.synth.supportsAudio()) {
				synthControl = new ABCJS.synth.SynthController();
				// synthControl.load("#audio", cursorControl, {displayLoop: true, displayRestart: true, displayPlay: true, displayProgress: true, displayWarp: true});
				synthControl.load("#audio", cursorControl, {displayLoop: true, displayRestart: true, displayPlay: true, displayProgress: true, displayWarp: true});

			} else {
				document.querySelector("#audio").innerHTML = "<div class='audio-error'>Audio is not supported in this browser.</div>";
			}
			setTune(false);

			
		}

		function download() {
			if (synthControl)
				synthControl.download(tuneNames[currentTune] + ".wav");
		}

		function start() {
			if (synthControl)
				synthControl.play();
				
		}

		function seek() {
			synthControl.seek(0.50)
		}

		function seekExplanation() {
			var explanation = document.getElementById("unit-explanation");
			if (!synthControl.visualObj.noteTimings) {
				explanation.innerText = "First start playing to load audio before seeking.";
				return;
			}
			var units = this.value;
			var max = 1;
			switch (units) {
				case "seconds":
					max = synthControl.visualObj.getTotalTime();
					break;
				case "beats":
					max = synthControl.visualObj.getTotalBeats();
					break;
			}
			explanation.innerText = "Enter a number between 0 and {0}.".replace("{0}", max);
		}

		function seek2() {
			var amount = document.getElementById("seek-amount").value;
			var units = document.getElementById("seek-units").value;
			synthControl.seek(amount, units)
		}

		function warp() {
			var el = document.querySelector(".warp");
			el.setAttribute("disabled", true)
			var amount = Math.random()
			console.log("warp", amount)
			synthControl.setWarp(amount*100).then(function () {
				el.removeAttribute("disabled")
			})
		}

		

		function setTune(userAction, r) {
			
			//  !!! TO-DO
			const reg = new RegExp("U");
			let pattern = document.getElementById("collection-selector").value;
			
			if (reg.test(pattern)){
				disabler("randomPattern", true)
				r = false; //this might not work -- maybe nest in if(r)
			} else {
				disabler("randomPattern", false)
			}

			let inst = 115;
			let abcString = abc[currentTune]

			if (r){
				// select two random bars 
				// var allTunes = selectTune.getElementsByTagName('option');
				var pattern1 = bars[Math.floor(Math.random() * bars.length)];
				var pattern2 = bars[Math.floor(Math.random() * bars.length)];
				// var pattern3 = bars[Math.floor(Math.random() * bars.length)];
				// var pattern4 = bars[Math.floor(Math.random() * bars.length)];
				// currentTune = tuneIndex;
				abcString = details + "\n" + pattern1 + pattern2; //+pattern3 +pattern4;
				console.log(abcString);
			}			
			var count = (abcString.match(/\|/g) || []).length;
			console.log(count);
			if (r){
				abcString += "\n";
			}
			abcString = abcString.split("\n");
			// abcString[0] += `\n%%MIDI program ${inst} `;
			abcString[0] += `\n%%MIDI channel 10 `;
			// let bar = (abcString[abcString.length-2]);
			// bars.push(bar);
			// console.log(abc.length);
			// console.log(currentTune);
			
			// add rests -- how do I figure out how many to add?
			if(currentTune == abc.length - 1 & !r){
				// abcString[abcString.length-2] += `\n`;	
				if (rests){
					abcString[abcString.length-1] += `Z${count}|`;	
				}
				// end of patternString
				abcString[abcString.length-1] += "|";
			
			}else{

				if (rests){
					abcString[abcString.length-2] += `Z${count}|`;	
				}
			// end of patternString
			abcString[abcString.length-2] += "|";
			}

			abcString = abcString.join("\n");
			console.log(abcString);
			var abcOptions = {
			add_classes: true,
			clickListener: self.clickListener,
			// responsive: "resize",
			// scale: 10
			//visualTranspose: visualTransposeHalfSteps
			//
			};
			var seekControls = document.querySelector(".seek-controls");
			seekControls.classList.add("disabled");
			synthControl.disable(true);
			// var visualObjOld = ABCJS.renderAbc("paper", abc[currentTune], abcOptions)[0];
			
			// Oct 6
			// 
			// var abc = abcEl.value;
			
			var visualObj = ABCJS.renderAbc("paper", abcString, abcOptions)[0];
			//var visualObj = ABCJS.strTranspose(abc, visualObj, -2)
			var midi = ABCJS.synth.getMidiFile(abc[currentTune]);
			var midiButton = document.querySelector(".midi");
			midiButton.innerHTML = midi;
			
			// midi transposition
			
			// let midiTransposeHalfSteps = visualTransposeHalfSteps + parseInt(document.getElementById("midi-transpose").value);
			// if(instAdjust % 12 != 0){
			// 	midiTransposeHalfSteps -= instAdjust;
			// }
		 const synthOpts = {
			//definitely mess with this for transposition
			midiTranspose: -11,
			//  this screws up the cursor at present
			//  drumIntro: 1
			//voicesOff: true,

			}
			// TODO-PER: This will allow the callback function to have access to timing info - this should be incorporated into the render at some point.
			var midiBuffer = new ABCJS.synth.CreateSynth();
			midiBuffer.init({
				//audioContext: new AudioContext(),
				visualObj: visualObj,
				// sequence: [],
				// millisecondsPerMeasure: 1000,
				// debugCallback: function(message) { console.log(message) },
				options: {
					soundFontUrl: "https://paulrosen.github.io/midi-js-soundfonts/MusyngKite/" ,
					// callbackContext: this,
					// onEnded: next(),
					// pan: [ -0.5, 0.5 ]
				}
                // console.log("You see me");
			}).then(function (response) {
				console.log(response);
				if (synthControl) {
					synthControl.setTune(visualObj, userAction, synthOpts).then(function (response) {
						console.log("Audio successfully loaded.")
						seekControls.classList.remove("disabled");
						seekExplanation();
					}).catch(function (error) {
						console.warn("Audio problem:", error);
					});
				}
			}).catch(function (error) {
				console.warn("Audio problem:", error);
			});
		}

		function sequenceCallback(tracks) {
				// The beats are 0.25 long so the amount of swing needs to be between 0 and 0.125,
				// but practically it needs to be a bit smaller so that it doesn't sound like a grace note.
				var swing = 0.1;
				var track = tracks[0];
				for (var i = 0; i < track.length; i++) {
					var event = track[i];
					if (event.start % 0.25) {
						// This is the off beat
						event.start += swing;
					} else {
						// This is the beat
						event.end += swing;
					}
				
				}
			}

		function next() {
			currentTune++;
			if (currentTune >= abc.length)
				currentTune = 0;
			document.getElementById('tune-selector').value = currentTune;
			setTune(true);
		}

		function pickTune() {
			currentTune =  document.getElementById('tune-selector').value;
			setTune(true);
		}


		// pickTune();
	</script>
</head>
<body onload="load()">
  <header>
  </header>
  <div class="container">
    <main>
      
      
		<button class="download" style="display: none;">Download</button>
		<div class="seek-controls disabled">
			<!-- change to "start at measure" -->
			<label>Seek: <input type="number" min="0" id="seek-amount"></label>
			<select aria-label="seek units" id="seek-units">
				<option value="percent">Percent</option>
				<option value="seconds">Seconds</option>
				<option value="beats">Beats</option>
			</select>
			<button class="seek2">Seek</button>
			<span id="unit-explanation" class="click-explanation">First start playing to load audio before seeking.</span>
		</div>
      <div class="midi">MIDI</div>
	  <div class="wrapper">
      <div id="paper"></div>
      
	</div>
	  
	  <br>
	  <div class="inflow">
		<div class="positioner"><!-- may not be needed: see notes below-->
		  <div class="fixed">
			<div id = "the-top" class="options">
				<div class="buddy">
				<select id="collection-selector" onchange="refreshCollection()"></select>
				<select id="tune-selector" onchange="pickTune()"></select>
				</div>
				<button class="next">Next</button>
				<button id="randomPattern" class="randomPattern" onclick="setTune(true, true)">Rand</button>
				
				<div id="audio"></div>
				<!-- <label for="rests-checkbox">Rests</label> -->
				<input type="checkbox" id="set-rests" onclick="setRests()">
					<!-- <input checked type="checkbox" id = "show-cursor" class="checkbox show-cursor" onchange="showCursor()"> -->
				
				<!-- <button class="start">Play</button> -->
				
				

				<!-- <div class="buddy">
					<label for="show-chords">Show chords?</label>
					<input checked type="checkbox" id = "show-chords" class="checkbox show-chords" onchange="showChords()"> -->
					<!-- </div> -->
				<!-- the below is a test button to change check states -->
				<!-- <button type="button" onclick="checkChanger('bass-clef', true)">Bass</button> -->
				
		
			</div>
		  </div>
		</div>
	  </div>

	  
	  <div class="tuneButtons">
      <button class="warp">Rand. Warp</button>
      <button class="seek">Seek to Middle</button>
	  </div>
      <p class="beat"></p>
      <p class="click-explanation" style="display:none;">Click on a note to play that note.</p>
      <pre class="clicked-info"></pre>
      <pre class="feedback"></pre>

	 
    </main>
  </div>
<script>
	//document.getElementById("abcText").value;
	var cursorControl = new CursorControl();
	showOptions();
	
	var selectCollection = document.getElementById("collection-selector");
			selectCollection.innerHTML = "";
			var option = document.createElement("option");
			for (i in patternObject) {
				option = document.createElement("option");
				optionContent = document.createTextNode(i);
				option.appendChild(optionContent);
				option.setAttribute('value', i)
				selectCollection.appendChild(option)
			}
	setTune();
  </script>
</script>	
</body>
</html>
